<?xml version="1.0" encoding="UTF-8"?>
<!--
  public/sitemap.xml — gisviz static sitemap
  ──────────────────────────────────────────
  This covers static pages only.
  For dynamic post and profile pages, generate a sitemap via
  app/sitemap.ts (Next.js 13+ metadata API) that calls the backend
  and yields URLs for all posts and public profiles.
  Replace gisviz.com with your actual domain before deploying.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <url>
    <loc>https://gisviz.com/</loc>
    <changefreq>hourly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://gisviz.com/privacy</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>

  <url>
    <loc>https://gisviz.com/terms</loc>
    <changefreq>monthly</changefreq>
    <priority>0.4</priority>
  </url>

  <url>
    <loc>https://gisviz.com/cookies</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>

  <url>
    <loc>https://gisviz.com/accessibility</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>

  <url>
    <loc>https://gisviz.com/contact</loc>
    <changefreq>yearly</changefreq>
    <priority>0.5</priority>
  </url>

</urlset>