# ── Git ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Dependencies (rebuilt inside Docker) ──────────────────────────
node_modules

# ── Next.js build cache (rebuilt inside Docker) ───────────────────
.next
/out
/build

# ── Environment & secrets (never go into image) ───────────────────
.env*
.env.local
.env.frontend
.env.production
.env.development

# ── OS / Editor ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Docker files (don't need to be inside the image) ──────────────
Dockerfile
docker-compose.yml
.dockerignore

# ── Testing & CI ──────────────────────────────────────────────────
/coverage
.github/

# ── Misc ──────────────────────────────────────────────────────────
README.md
*.md
.vercel